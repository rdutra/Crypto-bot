{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "bot_name": "local-llm-bot",
  "strategy": "LlmTrendPullbackStrategy",
  "max_open_trades": 2,
  "stake_currency": "USDT",
  "stake_amount": 50,
  "tradable_balance_ratio": 0.95,
  "fiat_display_currency": "USD",
  "dry_run": true,
  "dry_run_wallet": 300,
  "cancel_open_orders_on_exit": true,
  "process_only_new_candles": true,
  "trading_mode": "spot",
  "unfilledtimeout": {
    "entry": 10,
    "exit": 10,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },
  "entry_pricing": {
    "price_side": "other",
    "use_order_book": true,
    "order_book_top": 1
  },
  "exit_pricing": {
    "price_side": "other",
    "use_order_book": true,
    "order_book_top": 1
  },
  "exchange": {
    "name": "binance",
    "key": "",
    "secret": "",
    "ccxt_config": {
      "enableRateLimit": true
    },
    "ccxt_async_config": {
      "enableRateLimit": true
    },
    "pair_whitelist": [
      "BTC/USDT",
      "ETH/USDT"
    ],
    "pair_blacklist": []
  },
  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],
  "api_server": {
    "enabled": true,
    "listen_ip_address": "0.0.0.0",
    "listen_port": 8080,
    "verbosity": "error",
    "enable_openapi": true,
    "jwt_secret_key": "",
    "username": "freqtrade",
    "password": ""
  },
  "initial_state": "running",
  "force_entry_enable": false,
  "internals": {
    "process_throttle_secs": 5
  }
}
