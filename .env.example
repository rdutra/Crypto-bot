# Ollama
OLLAMA_MODEL=llama3.1:8b

# Strategy LLM controls (freqtrade container)
ENABLE_LLM_FILTER=false
LLM_MIN_CONFIDENCE=0.65
BOT_API_URL=http://bot-api:8000

# Binance credentials (used by docker-compose -> freqtrade env overrides)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Freqtrade API server credentials
# Generate with:
#   openssl rand -hex 32       -> FREQTRADE_API_JWT_SECRET
#   openssl rand -base64 24    -> FREQTRADE_API_PASSWORD
FREQTRADE_API_JWT_SECRET=
FREQTRADE_API_USERNAME=freqtrade
FREQTRADE_API_PASSWORD=
